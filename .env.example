# Salin file ini menjadi .env.local dan isi nilainya.
# .env.local TIDAK boleh di-commit (sudah ada di .gitignore).

# --- Supabase ---
# Project URL & keys dari Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Prisma) ---
# Connection string dari Project Settings → Database → Connection string (Session pooler, port 5432).
# Pastikan password sudah ter-substitusi.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- App ---
NEXT_PUBLIC_APP_NAME="Portal DTSEN Bangkalan"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron ---
# Token rahasia untuk melindungi endpoint cron (mis. reminder pelaporan).
CRON_SECRET=
